{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sop-oilfield-services/skins/customer.schema.json",
  "title": "CustomerSkin",
  "description": "TASK-13 customer.yaml schema. Configuration over code for customer skinning — brand, personas, hero scenario, terminology, KPI labels.",
  "type": "object",
  "required": ["meta", "personas", "taxonomy", "scenarios", "terminology", "kpi_labels"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "customer_slug",
        "customer_name",
        "customer_display_name",
        "color_primary",
        "color_secondary",
        "color_accent",
        "logo_path",
        "hero_path"
      ],
      "additionalProperties": false,
      "properties": {
        "customer_slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "customer_name": {"type": "string"},
        "customer_display_name": {"type": "string"},
        "short_name": {"type": "string"},
        "color_primary": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
        "color_secondary": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
        "color_accent": {"type": "string", "pattern": "^#[0-9a-fA-F]{6}$"},
        "logo_path": {"type": "string"},
        "hero_path": {"type": "string"},
        "tagline": {"type": "string"}
      }
    },
    "personas": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id",
          "number",
          "name",
          "role",
          "region",
          "sop_stage",
          "scenario_slug",
          "target_time_minutes",
          "opening_line",
          "memory_profile_user_id",
          "session_id"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string", "enum": ["david", "tomas", "maria", "priya", "rafael", "ayesha"]},
          "number": {"type": "integer", "minimum": 1, "maximum": 6},
          "name": {"type": "string"},
          "role": {"type": "string"},
          "region": {"type": "string"},
          "sop_stage": {"type": "string"},
          "scenario_slug": {"type": "string"},
          "target_time_minutes": {"type": "number", "exclusiveMinimum": 0},
          "opening_line": {"type": "string"},
          "memory_profile_user_id": {"type": "string"},
          "session_id": {"type": "string"}
        }
      }
    },
    "taxonomy": {
      "type": "object",
      "required": ["hero_asset"],
      "additionalProperties": false,
      "properties": {
        "hero_asset": {"$ref": "#/$defs/AssetEntry"},
        "secondary_assets": {
          "type": "array",
          "items": {"$ref": "#/$defs/AssetEntry"}
        }
      }
    },
    "scenarios": {
      "type": "object",
      "required": ["cargo-plane"],
      "additionalProperties": {"$ref": "#/$defs/ScenarioConfig"}
    },
    "terminology": {
      "type": "object",
      "required": [
        "occ_label",
        "fleet_unit_singular",
        "fleet_unit_plural",
        "regulatory_repository"
      ],
      "additionalProperties": false,
      "properties": {
        "occ_label": {"type": "string"},
        "occ_short": {"type": "string"},
        "basin_unit_label": {"type": "string"},
        "crew_unit_label": {"type": "string"},
        "fleet_unit_singular": {"type": "string"},
        "fleet_unit_plural": {"type": "string"},
        "capacity_gap_term": {"type": "string"},
        "sourcing_plan_term": {"type": "string"},
        "regulatory_repository": {"type": "string"},
        "audit_registry_label": {"type": "string"}
      }
    },
    "kpi_labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "short_label", "units"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "short_label": {"type": "string"},
          "units": {"type": "string", "enum": ["percent", "usd", "count", "hours", "days"]},
          "target_value": {"type": ["number", "null"]}
        }
      }
    }
  },
  "$defs": {
    "AssetEntry": {
      "type": "object",
      "required": ["canonical_id", "canonical_label", "category", "manufacturer"],
      "additionalProperties": false,
      "properties": {
        "canonical_id": {"type": "string"},
        "canonical_label": {"type": "string"},
        "category": {"type": "string"},
        "manufacturer": {"type": "string"},
        "equivalent_canonical_id": {"type": "string"},
        "equivalent_canonical_label": {"type": "string"}
      }
    },
    "ScenarioConfig": {
      "type": "object",
      "required": [
        "customer_account_slug",
        "customer_account_name",
        "location_focus_label",
        "asset_focus_label",
        "opening_prompt"
      ],
      "additionalProperties": false,
      "properties": {
        "customer_account_slug": {"type": "string"},
        "customer_account_name": {"type": "string"},
        "customer_account_short": {"type": "string"},
        "location_focus_label": {"type": "string"},
        "location_focus_lng": {"type": "number"},
        "location_focus_lat": {"type": "number"},
        "naive_origin_label": {"type": "string"},
        "naive_origin_lng": {"type": "number"},
        "naive_origin_lat": {"type": "number"},
        "recommended_origin_label": {"type": "string"},
        "recommended_origin_lng": {"type": "number"},
        "recommended_origin_lat": {"type": "number"},
        "asset_focus_canonical_id": {"type": "string"},
        "asset_focus_label": {"type": "string"},
        "naive_cost_usd": {"type": "number"},
        "recommended_cost_usd": {"type": "number"},
        "avoided_cost_usd": {"type": "number"},
        "deadline_phrase": {"type": "string"},
        "opening_prompt": {"type": "string"},
        "regulatory_reference": {"type": "string"}
      }
    }
  }
}
